# .env.example - Template for environment configuration
# Copy this file to .env and update values as needed

# ========================================
# Flask Settings
# ========================================
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=face_recognition_service.py

# ========================================
# Server Settings
# ========================================
HOST=0.0.0.0
PORT=5000

# ========================================
# Face Recognition Configuration
# ========================================
# Confidence threshold for face matching (0.0 to 1.0)
# Higher = more strict (recommended: 0.85)
CONFIDENCE_THRESHOLD=0.85

# Face detection model: 'hog' (fast, default) or 'cnn' (accurate, slower, GPU recommended)
FACE_RECOGNITION_MODEL=hog

# ========================================
# File Upload Settings
# ========================================
# Maximum file size in bytes (16MB default)
MAX_FILE_SIZE=16777216

# ========================================
# Logging
# ========================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========================================
# CORS Settings
# ========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:5000,http://gateway:8080,https://yourdomain.com

# ========================================
# Security
# ========================================
# Require API key for requests (recommended in production)
API_KEY_REQUIRED=False

# API Key (generate: openssl rand -hex 32)
# API_KEY=your_random_key_here_min_64_characters

# ========================================
# Database (future implementation)
# ========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/face_recognition_db
# REDIS_URL=redis://localhost:6379/0

# ========================================
# Performance Settings
# ========================================
# Number of workers for face detection processing
FACE_DETECTION_WORKERS=1

# Size of batches for batch processing
BATCH_PROCESSING_SIZE=5

# ========================================
# Timeouts (in seconds)
# ========================================
# General request timeout
REQUEST_TIMEOUT=30

# Image processing timeout
IMAGE_PROCESSING_TIMEOUT=20

# ========================================
# Verification Settings
# ========================================
# Maximum verification attempts per token
MAX_VERIFICATION_ATTEMPTS=3

# Token expiration time in minutes
TOKEN_EXPIRATION_MINUTES=45

# Number of verification logs to keep in memory
VERIFICATION_HISTORY_SIZE=1000

# ========================================
# Debug Features
# ========================================
# Enable debug endpoints (DISABLE in production!)
DEBUG_ENDPOINTS=False

# ========================================
# Monitoring & Metrics
# ========================================
# Enable Prometheus metrics endpoint
ENABLE_METRICS=True

# Port for metrics endpoint
METRICS_PORT=9090

# ========================================
# Production Settings (uncomment as needed)
# ========================================

# FLASK_ENV=production
# FLASK_DEBUG=False
# LOG_LEVEL=WARNING
# API_KEY_REQUIRED=True
# DEBUG_ENDPOINTS=False
