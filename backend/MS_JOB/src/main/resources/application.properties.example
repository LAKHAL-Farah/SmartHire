## Example application properties for MS_JOB
## Copy to application.properties and provide real values (DO NOT COMMIT secrets)

spring.application.name=MS_JOB
server.port=8085
spring.datasource.url=jdbc:mysql://localhost:3306/job_service?createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=${MYSQL_PASSWORD:change_me}

## NVIDIA integration
app.nvidia.api-key=${NVIDIA_NIM_API_KEY:}
app.nvidia.base-url=https://integrate.api.nvidia.com/v1
app.nvidia.model=meta/llama-3.1-70b-instruct
