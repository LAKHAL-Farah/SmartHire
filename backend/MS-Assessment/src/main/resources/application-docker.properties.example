# Example Docker profile properties for MS-Assessment (DO NOT COMMIT SECRETS)
# Copy to `application-docker.properties` when running with --spring.profiles.active=docker

spring.datasource.url=jdbc:mysql://localhost:3306/assessment_service?createDatabaseIfNotExist=true
spring.datasource.username=root
spring.datasource.password=${MYSQL_PASSWORD:change_me}

eureka.client.enabled=false
spring.cloud.discovery.enabled=false
